# Copia questo file in .env e personalizza i valori

# URL del server Ollama (default locale)
OLLAMA_URL=http://localhost:11434

# Modello da usare (phi3, mistral, llama3, ecc.)
# Se lasciato vuoto o commentato, la CLI ti chiederà di sceglierne uno
# OLLAMA_MODEL=llama3

# Timeout in secondi per la chiamata HTTP al modello
OLLAMA_TIMEOUT=180

# Percorso alla directory degli asset 3D
ASSETS_DIR=./assets/models

# Percorso di output render
RENDER_OUTPUT_DIR=./assets/renders

# Numero massimo di retry per il parsing JSON
MAX_RETRIES=3

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
