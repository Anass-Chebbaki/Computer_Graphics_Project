# Configurazione NL2Scene3D v2
# Copiare in .env e personalizzare

# === Provider LLM (Scelta Consigliata: Gemini) ===
# Gemini (cloud, free tier, estremamente veloce e preciso)
# Ottenere la chiave API gratuita su https://aistudio.google.com/
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama locale (backup o offline)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# === Timeout e retry ===
OLLAMA_TIMEOUT=180
MAX_RETRIES=3

# === Percorsi ===
ASSETS_DIR=./assets/models
RENDER_OUTPUT_DIR=./assets/renders

# === Logging ===
LOG_LEVEL=INFO